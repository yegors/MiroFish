# LLM API Configuration (Supports OpenAI, Anthropic, and OpenAI-compatible APIs)
# Provider auto-detected: uses Anthropic SDK when base_url contains "anthropic" or model starts with "claude"
# Recommended: Alibaba Bailian qwen-plus model: https://bailian.console.aliyun.com/
# Note: consumption is high, try simulations with less than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Anthropic Claude example =====
# LLM_API_KEY=sk-ant-xxxxx
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL_NAME=claude-sonnet-4-20250514

# ===== OpenAI example =====
# LLM_API_KEY=sk-xxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# Traditional models:
# LLM_MODEL_NAME=gpt-4o-mini
# GPT-5 family (auto-use max_completion_tokens, developer role, skip temperature):
# LLM_MODEL_NAME=gpt-5.4
# LLM_MODEL_NAME=gpt-5.2
# Reasoning models (same new-style params as GPT-5):
# LLM_MODEL_NAME=o4-mini

# ===== ZEPMemory map configuration =====
# Free monthly quota can support simple use：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerate LLM configuration（Optional）=====
# Note that if you do not use acceleration configuration，envDo not have the following configuration items appear in the file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here